# GoldTrust Wallet Environment Variables
# Copy this file to .env.local and update values as needed

# API Configuration (if backend is added in future)
# NEXT_PUBLIC_API_URL=https://api.example.com

# App Configuration
NEXT_PUBLIC_APP_NAME=GoldTrust Wallet
NEXT_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
NEXT_PUBLIC_ENABLE_MINING=true
NEXT_PUBLIC_ENABLE_WITHDRAWAL=true
NEXT_PUBLIC_ENABLE_REFERRAL=true

# WhatsApp Contacts
NEXT_PUBLIC_WHATSAPP_SUPPORT=2348161662371
NEXT_PUBLIC_WHATSAPP_PAYMENT=2348136347797
NEXT_PUBLIC_WHATSAPP_ACTIVATION=2347085462173
